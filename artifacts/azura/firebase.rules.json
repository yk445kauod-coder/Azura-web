{
  "rules": {
    ".read": false,
    ".write": false,
    "menu": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".indexOn": [
        "category",
        "available",
        "price"
      ]
    },
    "reels": {
      ".read": true,
      ".write": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".indexOn": [
        "createdAt",
        "pinned"
      ]
    },
    "orders": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": [
        "userId",
        "status",
        "createdAt"
      ]
    },
    "users": {
      "$uid": {
        ".read": true,
        ".write": "$uid === auth.uid"
      }
    },
    "admins": {
      ".read": true,
      ".write": false
    },
    "broadcast": {
      ".read": true,
      ".write": "root.child('admins').child(auth.uid).exists()"
    },
    "aiconfig": {
      ".read": true,
      ".write": "root.child('admins').child(auth.uid).exists()"
    },
    "apisettings": {
      ".read": true,
      ".write": "root.child('admins').child(auth.uid).exists()"
    },
    "suggestions": {
      ".read": true,
      ".write": true
    },
    "feedback": {
      ".read": true,
      ".write": true
    },
    "notifications": {
      "$uid": {
        ".read": true,
        ".write": true
      }
    }
  }
}